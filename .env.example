# PostgreSQL connection string. Use Vercel Postgres / Neon in production.
DATABASE_URL="postgresql://user:password@localhost:5432/section_selection?schema=public"

# Admin password (login screen at /admin/login).
ADMIN_PASSWORD="change-me"

# Random 32+ char string used to sign the admin session cookie.
SESSION_SECRET="change-this-to-a-long-random-string-at-least-32-chars"
